<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CHAOS — Leaner Nick Bare Protocol</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;700&family=Oswald:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#0a0e0a;
  --bg-card:#12181a;
  --bg-darker:#06090a;
  --accent:#ff6b1a;
  --green:#84cc16;
  --blue:#0ea5e9;
  --gold:#eab308;
  --red:#ef4444;
  --purple:#a855f7;
  --text:#e8e8e8;
  --text-dim:#888;
  --border:#1f2630;
}
body{
  background:var(--bg);
  color:var(--text);
  font-family:'Oswald',sans-serif;
  padding:12px;
  min-height:100vh;
  background-image:radial-gradient(circle at 20% 20%,rgba(255,107,26,.06) 0%,transparent 40%),radial-gradient(circle at 80% 80%,rgba(132,204,22,.04) 0%,transparent 40%);
}
.container{max-width:1400px;margin:0 auto}
header{text-align:center;margin-bottom:18px;padding:16px 0;border-top:3px solid var(--accent);border-bottom:3px solid var(--accent);position:relative}
header::before,header::after{content:'◆';position:absolute;color:var(--accent);font-size:.8em;top:50%;transform:translateY(-50%)}
header::before{left:8px}header::after{right:8px}
h1{font-family:'Bebas Neue',sans-serif;font-size:2em;color:var(--accent);letter-spacing:5px;text-shadow:0 0 20px rgba(255,107,26,.3)}
.tagline{color:var(--text-dim);font-size:.7em;text-transform:uppercase;letter-spacing:2px;margin-top:4px;font-family:'JetBrains Mono',monospace}

.weight-check{background:linear-gradient(135deg,var(--bg-card),var(--bg-darker));border:2px solid var(--gold);border-radius:8px;padding:14px;margin-bottom:14px}
.weight-check-title{font-family:'Bebas Neue',sans-serif;color:var(--gold);font-size:1.2em;letter-spacing:2px;margin-bottom:10px;text-align:center}
.weight-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.weight-cell{background:var(--bg-darker);padding:10px;border-radius:5px;text-align:center;border:1px solid var(--border)}
.weight-cell-label{color:var(--text-dim);font-size:.65em;text-transform:uppercase;letter-spacing:1px;font-family:'JetBrains Mono',monospace}
.weight-cell-val{color:var(--gold);font-family:'Bebas Neue',sans-serif;font-size:1.6em;margin-top:4px;letter-spacing:1px}
.weight-input-row{display:flex;gap:8px;margin-top:8px}
.weight-input{flex:1;background:var(--bg-darker);border:1px solid var(--border);color:var(--text);padding:10px;border-radius:5px;font-family:'JetBrains Mono',monospace;font-size:1em;text-align:center}
.weight-input:focus{outline:none;border-color:var(--gold)}
.weight-save-btn{background:var(--gold);color:#000;border:none;padding:10px 16px;font-weight:700;border-radius:5px;cursor:pointer;font-family:'Oswald',sans-serif;text-transform:uppercase;font-size:.85em;letter-spacing:1px}
.weight-history{margin-top:10px;padding-top:10px;border-top:1px dashed var(--border);max-height:150px;overflow-y:auto}
.weight-entry{display:flex;justify-content:space-between;padding:5px 0;font-size:.85em;border-bottom:1px solid var(--border);font-family:'JetBrains Mono',monospace}
.weight-entry-date{color:var(--text-dim)}
.weight-entry-val{color:var(--gold);font-weight:700}
.weight-trend-up{color:var(--red)}
.weight-trend-down{color:var(--green)}
.weight-status{padding:8px;background:var(--bg-darker);border-radius:5px;margin-top:8px;text-align:center;font-size:.85em}
.weight-status.on-track{border:1px solid var(--green);color:var(--green)}
.weight-status.ahead{border:1px solid var(--blue);color:var(--blue)}
.weight-status.behind{border:1px solid var(--red);color:var(--red)}

.goals{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:14px}
.goal{background:var(--bg-card);border:1px solid var(--border);border-top:3px solid var(--accent);padding:8px 6px;text-align:center;border-radius:0 0 4px 4px}
.goal-icon{font-size:1.1em;margin-bottom:2px}
.goal-label{font-family:'JetBrains Mono',monospace;font-size:.6em;color:var(--text-dim);letter-spacing:1px;text-transform:uppercase}
.goal-val{font-family:'Bebas Neue',sans-serif;font-size:1em;color:var(--accent);letter-spacing:1px;margin-top:2px}

.tabs{display:flex;gap:3px;margin-bottom:14px;overflow-x:auto;padding-bottom:3px}
.tabs::-webkit-scrollbar{height:0}
.tab{padding:9px 14px;background:var(--bg-card);border:1px solid var(--border);color:var(--text-dim);cursor:pointer;font-family:'Oswald',sans-serif;font-weight:600;font-size:.75em;text-transform:uppercase;letter-spacing:1.5px;white-space:nowrap;flex-shrink:0;border-bottom:3px solid transparent}
.tab.active{background:var(--bg-darker);color:var(--accent);border-bottom-color:var(--accent)}

.phase-banner{background:var(--bg-card);border-left:5px solid var(--accent);padding:12px 14px;margin-bottom:12px;border-radius:0 6px 6px 0}
.phase-week-num{font-family:'Bebas Neue',sans-serif;font-size:2.2em;line-height:1;color:var(--accent)}
.phase-label{font-family:'Bebas Neue',sans-serif;font-size:1.1em;letter-spacing:3px}
.phase-desc{color:var(--text-dim);font-size:.78em;margin-top:5px}

.week-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px;margin-bottom:12px;padding:8px;background:var(--bg-card);border:1px solid var(--border);border-radius:4px}
.wk-btn{padding:5px 2px;background:var(--bg-darker);border:1px solid var(--border);color:var(--text-dim);cursor:pointer;font-family:'JetBrains Mono',monospace;font-weight:700;font-size:.65em;border-radius:2px}
.wk-btn.active{background:var(--accent);color:#000;border-color:var(--accent)}

.day-card{background:var(--bg-card);border:1px solid var(--border);border-left:4px solid var(--accent);padding:12px;margin-bottom:10px;border-radius:0 6px 6px 0}
.day-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;padding-bottom:8px;border-bottom:1px dashed var(--border);gap:8px}
.day-name{font-family:'Bebas Neue',sans-serif;color:var(--accent);font-size:1.3em;letter-spacing:3px}
.day-title{color:var(--text);font-size:.78em;margin-top:2px;text-transform:uppercase;letter-spacing:1px}
.day-tag{background:var(--accent);color:#000;padding:3px 8px;font-family:'JetBrains Mono',monospace;font-size:.6em;font-weight:700;letter-spacing:1px;border-radius:2px}

.ex{background:var(--bg-darker);padding:9px 11px;margin-bottom:7px;border-left:2px solid var(--green);border-radius:0 3px 3px 0}
.ex-name{color:#fff;font-weight:600;font-size:.88em;margin-bottom:6px}
.ex-meta{display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px;margin-bottom:5px}
.meta-cell{background:var(--bg);padding:4px 6px;border-radius:2px;border:1px solid var(--border)}
.meta-label{color:var(--text-dim);font-size:.55em;text-transform:uppercase;letter-spacing:1px;font-family:'JetBrains Mono',monospace}
.meta-val{color:var(--green);font-weight:700;font-size:.8em;margin-top:2px;font-family:'JetBrains Mono',monospace}
.weight-val{color:var(--gold)}
.rpe-val{color:var(--blue)}
.ex-note{background:rgba(132,204,22,.06);border-left:2px solid var(--green);padding:4px 7px;font-size:.7em;color:#9bc99c;border-radius:0 2px 2px 0;font-style:italic}
.abs-block{background:rgba(132,204,22,.08);border:1px solid var(--green);padding:9px 11px;margin-top:9px;border-radius:3px}
.abs-label{font-family:'Bebas Neue',sans-serif;color:var(--green);font-size:.9em;letter-spacing:2px;margin-bottom:4px}
.abs-list{color:#b0e0a0;font-size:.72em;line-height:1.5}

.run-card{background:var(--bg-card);border:1px solid var(--border);padding:12px;margin-bottom:9px;border-radius:0 5px 5px 0;border-left:4px solid var(--blue)}
.run-day-name{font-family:'Bebas Neue',sans-serif;color:var(--blue);font-size:1.2em;letter-spacing:2px;margin-bottom:6px}
.run-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:5px}
.run-stat{background:var(--bg-darker);padding:6px;border-radius:2px;text-align:center}
.run-stat-label{color:var(--text-dim);font-size:.6em;text-transform:uppercase;letter-spacing:1px;font-family:'JetBrains Mono',monospace}
.run-stat-val{color:var(--blue);font-weight:700;font-size:.85em;margin-top:2px;font-family:'JetBrains Mono',monospace}

.macro-card{background:var(--bg-card);border:1px solid var(--border);padding:12px;margin-bottom:9px;border-radius:0 5px 5px 0;border-left:4px solid var(--gold)}
.macro-title{font-family:'Bebas Neue',sans-serif;color:var(--gold);font-size:1.1em;letter-spacing:2px;margin-bottom:7px}
.macro-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
.macro-item{background:var(--bg-darker);padding:9px;text-align:center;border-radius:3px;border:1px solid var(--border)}
.macro-item-label{color:var(--text-dim);font-size:.65em;text-transform:uppercase;letter-spacing:1.5px;font-family:'JetBrains Mono',monospace}
.macro-item-val{color:var(--gold);font-weight:700;font-size:1.2em;margin-top:4px;font-family:'JetBrains Mono',monospace}

.principle{background:var(--bg-card);border:1px solid var(--border);padding:12px;margin-bottom:9px;border-radius:0 5px 5px 0;border-left:3px solid var(--accent)}
.principle-title{font-family:'Bebas Neue',sans-serif;color:var(--accent);font-size:1em;letter-spacing:2px;margin-bottom:4px}
.principle-text{color:#ccc;font-size:.8em;line-height:1.55}

.section-hidden{display:none}

.target-banner{background:linear-gradient(135deg,var(--bg-card),var(--bg-darker));border:2px solid var(--green);border-radius:8px;padding:12px;margin-bottom:14px;text-align:center}
.target-label{font-family:'JetBrains Mono',monospace;color:var(--text-dim);font-size:.7em;letter-spacing:2px;text-transform:uppercase}
.target-weight{font-family:'Bebas Neue',sans-serif;color:var(--green);font-size:2.5em;line-height:1;letter-spacing:2px;margin-top:4px}
.target-bf{color:var(--text-dim);font-size:.85em;margin-top:4px}

@media(min-width:768px){
  h1{font-size:2.6em;letter-spacing:7px}
  body{padding:18px}
  .day-card{padding:18px}
  .ex{padding:12px 14px}
  .wk-btn{font-size:.75em;padding:8px 4px}
  .week-grid{grid-template-columns:repeat(13,1fr)}
}
</style>
</head>
<body>
<div class="container">

<header>
<h1>⚔ CHAOS ⚔</h1>
<div class="tagline">Leaner Nick Bare Protocol • 26-Week Mission</div>
</header>

<div class="weight-check">
<div class="weight-check-title">📊 Daily Weight Check-In</div>
<div class="weight-row">
<div class="weight-cell">
<div class="weight-cell-label">Today's Target</div>
<div class="weight-cell-val" id="targetToday">—</div>
</div>
<div class="weight-cell">
<div class="weight-cell-label">Last Logged</div>
<div class="weight-cell-val" id="lastWeight">—</div>
</div>
</div>
<div class="weight-input-row">
<input type="number" step="0.1" class="weight-input" id="weightInput" placeholder="Morning weight (lbs)">
<button class="weight-save-btn" onclick="saveWeight()">LOG</button>
</div>
<div class="weight-status" id="weightStatus">Log your morning weight to see your progress</div>
<div class="weight-history" id="weightHistory"></div>
</div>

<div class="target-banner">
<div class="target-label">Week Target Weight</div>
<div class="target-weight" id="weekTargetDisplay">216 lbs</div>
<div class="target-bf" id="weekBFDisplay">~23% BF</div>
</div>

<div class="goals">
<div class="goal">
<div class="goal-icon">🎯</div>
<div class="goal-label">June 18</div>
<div class="goal-val">SUB 200</div>
</div>
<div class="goal">
<div class="goal-icon">🦅</div>
<div class="goal-label">August</div>
<div class="goal-val">MIL TRAIN</div>
</div>
<div class="goal">
<div class="goal-icon">🏆</div>
<div class="goal-label">October</div>
<div class="goal-val">185 / 10%</div>
</div>
</div>

<div class="tabs">
<div class="tab active" data-tab="lift">💪 Lift</div>
<div class="tab" data-tab="run">🏃 Run</div>
<div class="tab" data-tab="macros">📊 Macros</div>
<div class="tab" data-tab="strategy">🧠 Strategy</div>
</div>

<div id="lift-section">
<div class="phase-banner" id="phaseBanner"></div>
<div class="week-grid" id="weekGrid"></div>
<div id="workouts"></div>
</div>

<div id="run-section" class="section-hidden">
<div class="week-grid" id="runWeekGrid"></div>
<div id="runContent"></div>
</div>

<div id="macros-section" class="section-hidden">
<div class="macro-card">
<div class="macro-title">Daily Targets (Locked)</div>
<div class="macro-grid">
<div class="macro-item"><div class="macro-item-label">Calories</div><div class="macro-item-val">1,400</div></div>
<div class="macro-item"><div class="macro-item-label">Protein</div><div class="macro-item-val">200g</div></div>
<div class="macro-item"><div class="macro-item-label">Carbs</div><div class="macro-item-val">60g</div></div>
</div>
<div class="macro-grid" style="margin-top:6px">
<div class="macro-item"><div class="macro-item-label">Fat</div><div class="macro-item-val">40g</div></div>
</div>
</div>
<div class="principle">
<div class="principle-title">🌅 Daily Fasted Protocol</div>
<div class="principle-text">Pre-workout: Black coffee + 5g creatine + electrolytes. Post-lift: 30g whey within 30 min. First meal 60-90 min later. Stay hydrated all day.</div>
</div>
<div class="principle">
<div class="principle-title">⚠️ Yellow Flags</div>
<div class="principle-text">Watch for: strength drop 10%+, sleep below 6/10 for a week, cold extremities, weight stall 2+ weeks. Adjust if you see these.</div>
</div>
<div class="principle">
<div class="principle-title">💧 Weighing Protocol</div>
<div class="principle-text">Every morning, after bathroom, before food/water, naked or in underwear only. Same scale, same spot, same time. Trust the trend over 7 days, not daily fluctuations.</div>
</div>
</div>

<div id="strategy-section" class="section-hidden">
<div class="principle">
<div class="principle-title">🎯 Leaner Nick Bare Target</div>
<div class="principle-text">Hybrid athlete physique scaled to 5'11"-6'0": 185 lbs at 10% body fat. Wide shoulders, tight waist, visible 6-pack, defined chest (not bulky), athletic runner legs. You start at 216 lbs / ~23% BF with great muscle base.</div>
</div>
<div class="principle">
<div class="principle-title">📅 26-Week Phase Map</div>
<div class="principle-text">
<strong style="color:var(--red)">W1-6 Cut A:</strong> 216→200, build base, max ROI lifts<br>
<strong style="color:var(--accent)">W7-10 Cut B:</strong> 200→194, June 18 vacation<br>
<strong style="color:var(--gold)">W11 Refeed:</strong> Restore glycogen post-July 4<br>
<strong style="color:var(--green)">W12-17 Lean Build:</strong> 194→192, muscle rebuild for Aug training<br>
<strong style="color:var(--blue)">W18-22 Performance:</strong> Military training, 5K push<br>
<strong style="color:var(--purple)">W23-26 Peak:</strong> 188→185 final shred
</div>
</div>
<div class="principle">
<div class="principle-title">🦅 Back Shred Strategy</div>
<div class="principle-text">Hit back 2x/week: heavy rows (thickness) + weighted pull-ups (width) + lat pullovers (V-taper). All three together build the shredded back look.</div>
</div>
<div class="principle">
<div class="principle-title">💪 Chest Lean-Out</div>
<div class="principle-text">Bench press stays IN. Flat bench Mon for compound strength, incline Fri for upper chest "shelf" that lifts saggy look. Cable crossovers for definition. Fat loss reveals it all.</div>
</div>
<div class="principle">
<div class="principle-title">🎖️ Gut Annihilation</div>
<div class="principle-text">Visible abs require ~10-12% body fat. No spot reduction. The gut goes when total body fat drops. AB FORGE 4x/week builds the muscle. Diet reveals it.</div>
</div>
<div class="principle">
<div class="principle-title">🏃 5K Sub-20 Path</div>
<div class="principle-text">Currently 28:09 → target sub-20 Oct. Tempo runs build lactate threshold. Long runs build aerobic base. Easy runs for recovery. Lose weight = run faster (each lb = 2-3 sec/mi).</div>
</div>
<div class="principle">
<div class="principle-title">🔑 Non-Negotiables</div>
<div class="principle-text">• Hit 200g protein daily<br>• Morning weigh-ins only<br>• 7+ hours sleep<br>• Track MyFitnessPal daily<br>• Don't eat back exercise calories<br>• Missed workouts ≠ makeup workouts<br>• Log weight here daily</div>
</div>
</div>

</div>

<script>
// Target weight per week (linear progression with phase adjustments)
const targetWeights = {
  1: 216, 2: 213, 3: 211, 4: 208, 5: 205, 6: 202,
  7: 200, 8: 198, 9: 196, 10: 194,
  11: 195,
  12: 194, 13: 193, 14: 193, 15: 192, 16: 192, 17: 191,
  18: 190, 19: 189, 20: 188, 21: 188, 22: 187,
  23: 187, 24: 186, 25: 185, 26: 185
};

const targetBF = {
  1: '~23%', 2: '~22%', 3: '~21%', 4: '~20%', 5: '~19%', 6: '~18%',
  7: '~17%', 8: '~16%', 9: '~15%', 10: '~14%',
  11: '~14%',
  12: '~14%', 13: '~13%', 14: '~13%', 15: '~13%', 16: '~12%', 17: '~12%',
  18: '~12%', 19: '~11%', 20: '~11%', 21: '~11%', 22: '~10%',
  23: '~10%', 24: '~10%', 25: '~10%', 26: '~10%'
};

const PHASES = {
  cutA: {label:'CUT PHASE A',color:'#ef4444',desc:'Aggressive deficit. Strength preservation. 216→200 lbs.'},
  cutB: {label:'CUT PHASE B',color:'#ff6b1a',desc:'Pre-vacation peak. June 18 deadline. 200→194 lbs.'},
  refeed: {label:'REFEED WEEK',color:'#eab308',desc:'Restore glycogen. Reset hormones. Prep next phase.'},
  build: {label:'LEAN BUILD',color:'#84cc16',desc:'Muscle rebuild. Prep August military training.'},
  perform: {label:'PERFORMANCE',color:'#0ea5e9',desc:'Military training. 5K push. Maintain weight.'},
  peak: {label:'PEAK PHASE',color:'#a855f7',desc:'Final shred. Sub-20 5K. Nick Bare physique by October.'}
};

function getPhase(week) {
  if (week <= 6) return 'cutA';
  if (week <= 10) return 'cutB';
  if (week === 11) return 'refeed';
  if (week <= 17) return 'build';
  if (week <= 22) return 'perform';
  return 'peak';
}

function getWeight(base, week, perWeek) {
  return base + ((week - 1) * perWeek);
}

function buildWorkouts(week) {
  return {
    mon: {
      name: 'MON',
      title: 'Upper A — Back Thickness + Chest',
      tag: 'BACK / PUSH',
      exercises: [
        {name:'Flat Barbell Bench Press', sets:'4×8', weight:`${getWeight(175, week, 5)} lbs`, rpe:'8/10', note:'3s eccentric. Chest tight, full ROM. Anchor lift.'},
        {name:'Bent-Over Barbell Row', sets:'4×10', weight:`${getWeight(165, week, 5)} lbs`, rpe:'8/10', note:'Squeeze 1s at top. Mid-back thickness.'},
        {name:'Weighted Pull-Up', sets:'4×8', weight:`BW + ${getWeight(20, week, 2)} lbs`, rpe:'8/10', note:'Full ROM. Drop weight if reps under 8.'},
        {name:'Incline DB Press', sets:'3×10', weight:`${getWeight(55, week, 2)} lbs ea`, rpe:'7/10', note:'Upper chest shelf builder.'},
        {name:'Cable Face Pull', sets:'3×15', weight:`${getWeight(45, week, 2)} lbs`, rpe:'7/10', note:'Rear delts + posture. High reps.'},
      ],
      abs: 'Cable Crunch 4×12 (+2.5 lbs/wk) • Hanging Leg Raise 4×10 • Plank 3×60s'
    },
    wed: {
      name: 'WED',
      title: 'Lower A — Quad/Glute (Light, recover from Tue long run)',
      tag: 'LOWER / MODERATE',
      exercises: [
        {name:'Goblet Squat or Leg Press', sets:'4×10', weight:`${getWeight(160, week, 5)} lbs / ${getWeight(225, week, 10)} lbs`, rpe:'7/10', note:'Lighter than max. Recovery from Tue run.'},
        {name:'Romanian Deadlift', sets:'3×10', weight:`${getWeight(185, week, 5)} lbs`, rpe:'7/10', note:'Slow eccentric. Hamstring stretch.'},
        {name:'Walking Lunges', sets:'3×10/leg', weight:`${getWeight(30, week, 2)} lbs ea`, rpe:'7/10', note:'Bodyweight if legs cooked.'},
        {name:'Leg Curl', sets:'4×12', weight:`${getWeight(100, week, 5)} lbs`, rpe:'8/10', note:'Pause + squeeze.'},
        {name:'Standing Calf Raise', sets:'4×15', weight:`${getWeight(180, week, 5)} lbs`, rpe:'7/10', note:'3s descent.'},
      ],
      abs: 'Decline Crunch 4×12 (+2.5 lbs/wk) • Pallof Press 4×12/side • Dead Bug 3×10/side'
    },
    fri: {
      name: 'FRI',
      title: 'Upper B — Back Width + Upper Chest',
      tag: 'PULL / CHEST',
      exercises: [
        {name:'Incline Barbell Bench', sets:'4×8', weight:`${getWeight(135, week, 5)} lbs`, rpe:'8/10', note:'Upper chest shelf. Lifts saggy look.'},
        {name:'Weighted Pull-Up', sets:'4×6', weight:`BW + ${getWeight(25, week, 2)} lbs`, rpe:'8/10', note:'Heavy day. Pure lat width.'},
        {name:'Pendlay Row', sets:'4×8', weight:`${getWeight(165, week, 5)} lbs`, rpe:'8/10', note:'Dead-stop. Explosive concentric.'},
        {name:'Cable Lat Pullover', sets:'3×12', weight:`${getWeight(55, week, 2)} lbs`, rpe:'7/10', note:'V-taper builder.'},
        {name:'Cable Crossover (Low to High)', sets:'3×15', weight:`${getWeight(20, week, 1)} lbs ea`, rpe:'7/10', note:'Upper chest definition.'},
        {name:'DB Lateral Raise', sets:'4×15', weight:`${getWeight(15, week, 1)} lbs ea`, rpe:'7/10', note:'Shoulders = V-taper.'},
      ],
      abs: 'Ab Wheel Rollout 4×8 • Cable Woodchops 4×12/side • Hollow Body Hold 3×30s'
    },
    sun: {
      name: 'SUN',
      title: 'Lower B — Posterior Chain + Core (HEAVY day)',
      tag: 'POSTERIOR / CORE',
      exercises: [
        {name:'Trap Bar Deadlift', sets:'4×6', weight:`${getWeight(235, week, 5)} lbs`, rpe:'8/10', note:'Heavy day. Reset each rep. Main lower lift.'},
        {name:'Hip Thrust', sets:'4×12', weight:`${getWeight(185, week, 5)} lbs`, rpe:'8/10', note:'Squeeze 2s at top. Glute hypertrophy.'},
        {name:'Bulgarian Split Squat', sets:'3×10/leg', weight:`${getWeight(35, week, 2)} lbs ea`, rpe:'8/10', note:'Glute + balance + core.'},
        {name:'Single-Leg RDL', sets:'3×10/leg', weight:`${getWeight(30, week, 1)} lbs ea`, rpe:'7/10', note:'Hamstring stretch + balance.'},
        {name:"Farmer's Carry", sets:'4×40m', weight:`${getWeight(75, week, 2)} lbs ea`, rpe:'8/10', note:'Core under load. Grip work.'},
      ],
      abs: 'Hanging Leg Raise 4×10 (weighted by W12) • Cable Crunch 4×15 • Side Plank 3×30s/side'
    }
  };
}

function getRunning(week) {
  if (week <= 6) {
    return {
      tue: {dist:`${(5 + (week-1)*0.3).toFixed(1)} mi`, pace:'9:30-10:00', type:'Long Run'},
      thu: {dist:`${(2.5 + (week-1)*0.1).toFixed(1)} mi`, pace:'9:45-10:15', type:'Easy Recovery'},
      sat: {dist:`${(3 + (week-1)*0.1).toFixed(1)} mi`, pace:'8:30-8:45', type:'Tempo'}
    };
  }
  if (week <= 10) {
    return {
      tue: {dist:`${(7 + (week-7)*0.3).toFixed(1)} mi`, pace:'9:15-9:45', type:'Long Run'},
      thu: {dist:`${(3 + (week-7)*0.1).toFixed(1)} mi`, pace:'9:30-10:00', type:'Easy Recovery'},
      sat: {dist:`${(3.5 + (week-7)*0.1).toFixed(1)} mi`, pace:'8:15-8:30', type:'Tempo'}
    };
  }
  if (week === 11) {
    return {
      tue: {dist:'5.0 mi', pace:'10:00 easy', type:'Recovery Long'},
      thu: {dist:'3.0 mi', pace:'10:00', type:'Easy Recovery'},
      sat: {dist:'3.0 mi', pace:'9:00', type:'Light Tempo'}
    };
  }
  if (week <= 17) {
    return {
      tue: {dist:`${(8 + (week-12)*0.3).toFixed(1)} mi`, pace:'9:00-9:30', type:'Long Run'},
      thu: {dist:`${(3 + (week-12)*0.1).toFixed(1)} mi`, pace:'9:15-9:45', type:'Easy Recovery'},
      sat: {dist:`${(4 + (week-12)*0.1).toFixed(1)} mi`, pace:'8:00-8:15', type:'Tempo'}
    };
  }
  if (week <= 22) {
    return {
      tue: {dist:`${(9 + (week-18)*0.3).toFixed(1)} mi`, pace:'8:45-9:15', type:'Long Run'},
      thu: {dist:`${(3.5 + (week-18)*0.1).toFixed(1)} mi`, pace:'9:00-9:30', type:'Easy Recovery'},
      sat: {dist:'6×800m', pace:'7:30/mi', type:'Intervals'}
    };
  }
  return {
    tue: {dist:`${(8 + (week-23)*0.3).toFixed(1)} mi`, pace:'8:30-9:00', type:'Long Run'},
    thu: {dist:`${(4 + (week-23)*0.1).toFixed(1)} mi`, pace:'8:45-9:15', type:'Easy Recovery'},
    sat: {dist:'5K Race Pace', pace:'6:45-7:00/mi', type:'Race Sim'}
  };
}

let currentWeek = 1;

function renderWeekGrid(containerId) {
  const grid = document.getElementById(containerId);
  grid.innerHTML = '';
  for (let i = 1; i <= 26; i++) {
    const btn = document.createElement('div');
    btn.className = 'wk-btn' + (i === currentWeek ? ' active' : '');
    btn.textContent = 'W' + i;
    btn.onclick = () => { currentWeek = i; renderAll(); };
    grid.appendChild(btn);
  }
}

function renderPhaseBanner() {
  const phaseKey = getPhase(currentWeek);
  const phase = PHASES[phaseKey];
  const banner = document.getElementById('phaseBanner');
  banner.style.borderLeftColor = phase.color;
  banner.innerHTML = `<div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap"><div class="phase-week-num">W${currentWeek.toString().padStart(2,'0')}</div><div style="flex:1;min-width:200px"><div class="phase-label" style="color:${phase.color}">${phase.label}</div><div class="phase-desc">${phase.desc}</div></div></div>`;
  document.getElementById('weekTargetDisplay').textContent = targetWeights[currentWeek] + ' lbs';
  document.getElementById('weekBFDisplay').textContent = targetBF[currentWeek] + ' BF';
}

function renderWorkouts() {
  const workouts = buildWorkouts(currentWeek);
  const container = document.getElementById('workouts');
  container.innerHTML = '';
  ['mon','wed','fri','sun'].forEach(day => {
    const w = workouts[day];
    let exHTML = w.exercises.map(e => `<div class="ex"><div class="ex-name">${e.name}</div><div class="ex-meta"><div class="meta-cell"><div class="meta-label">Sets×Reps</div><div class="meta-val">${e.sets}</div></div><div class="meta-cell"><div class="meta-label">Weight</div><div class="meta-val weight-val">${e.weight}</div></div><div class="meta-cell"><div class="meta-label">RPE</div><div class="meta-val rpe-val">${e.rpe}</div></div></div><div class="ex-note">▸ ${e.note}</div></div>`).join('');
    container.innerHTML += `<div class="day-card"><div class="day-header"><div><div class="day-name">${w.name}</div><div class="day-title">${w.title}</div></div><div class="day-tag">${w.tag}</div></div>${exHTML}<div class="abs-block"><div class="abs-label">🔥 AB FORGE</div><div class="abs-list">${w.abs}</div></div></div>`;
  });
}

function renderRunning() {
  const r = getRunning(currentWeek);
  const c = document.getElementById('runContent');
  c.innerHTML = `<div class="run-card"><div class="run-day-name">TUE — ${r.tue.type}</div><div class="run-stats"><div class="run-stat"><div class="run-stat-label">Distance</div><div class="run-stat-val">${r.tue.dist}</div></div><div class="run-stat"><div class="run-stat-label">Pace</div><div class="run-stat-val">${r.tue.pace}</div></div><div class="run-stat"><div class="run-stat-label">Type</div><div class="run-stat-val">${r.tue.type}</div></div></div></div><div class="run-card"><div class="run-day-name">THU — ${r.thu.type}</div><div class="run-stats"><div class="run-stat"><div class="run-stat-label">Distance</div><div class="run-stat-val">${r.thu.dist}</div></div><div class="run-stat"><div class="run-stat-label">Pace</div><div class="run-stat-val">${r.thu.pace}</div></div><div class="run-stat"><div class="run-stat-label">Type</div><div class="run-stat-val">${r.thu.type}</div></div></div></div><div class="run-card"><div class="run-day-name">SAT — ${r.sat.type}</div><div class="run-stats"><div class="run-stat"><div class="run-stat-label">Distance</div><div class="run-stat-val">${r.sat.dist}</div></div><div class="run-stat"><div class="run-stat-label">Pace</div><div class="run-stat-val">${r.sat.pace}</div></div><div class="run-stat"><div class="run-stat-label">Type</div><div class="run-stat-val">${r.sat.type}</div></div></div></div>`;
}

// Weight tracking with localStorage
function getWeightLog() {
  try {
    return JSON.parse(localStorage.getItem('chaosWeightLog') || '[]');
  } catch { return []; }
}

function saveWeight() {
  const input = document.getElementById('weightInput');
  const val = parseFloat(input.value);
  if (!val || val < 100 || val > 400) {
    alert('Enter a valid weight (100-400 lbs)');
    return;
  }
  const log = getWeightLog();
  const today = new Date().toISOString().split('T')[0];
  const existing = log.findIndex(e => e.date === today);
  if (existing >= 0) {
    log[existing].weight = val;
    log[existing].week = currentWeek;
  } else {
    log.push({date: today, weight: val, week: currentWeek});
  }
  localStorage.setItem('chaosWeightLog', JSON.stringify(log));
  input.value = '';
  renderWeightCheck();
}

function renderWeightCheck() {
  const log = getWeightLog();
  const target = targetWeights[currentWeek];
  document.getElementById('targetToday').textContent = target + ' lbs';
  
  if (log.length === 0) {
    document.getElementById('lastWeight').textContent = '—';
    document.getElementById('weightStatus').textContent = 'Log your morning weight to see your progress';
    document.getElementById('weightStatus').className = 'weight-status';
    document.getElementById('weightHistory').innerHTML = '';
    return;
  }
  
  const sorted = log.slice().sort((a,b) => b.date.localeCompare(a.date));
  const latest = sorted[0];
  document.getElementById('lastWeight').textContent = latest.weight + ' lbs';
  
  // Status
  const diff = latest.weight - target;
  const statusEl = document.getElementById('weightStatus');
  if (Math.abs(diff) <= 1) {
    statusEl.textContent = `✅ ON TRACK — ${diff > 0 ? '+' : ''}${diff.toFixed(1)} lbs from target`;
    statusEl.className = 'weight-status on-track';
  } else if (diff < 0) {
    statusEl.textContent = `🚀 AHEAD OF SCHEDULE — ${diff.toFixed(1)} lbs below target`;
    statusEl.className = 'weight-status ahead';
  } else {
    statusEl.textContent = `⚠️ BEHIND TARGET — ${diff.toFixed(1)} lbs above target. Check diet/cardio.`;
    statusEl.className = 'weight-status behind';
  }
  
  // History
  const history = document.getElementById('weightHistory');
  history.innerHTML = sorted.slice(0, 14).map((entry, i) => {
    const prev = sorted[i + 1];
    let trend = '';
    if (prev) {
      const change = entry.weight - prev.weight;
      if (change > 0.1) trend = `<span class="weight-trend-up">+${change.toFixed(1)}</span>`;
      else if (change < -0.1) trend = `<span class="weight-trend-down">${change.toFixed(1)}</span>`;
      else trend = '—';
    }
    const date = new Date(entry.date).toLocaleDateString('en-US', {month:'short', day:'numeric'});
    return `<div class="weight-entry"><span class="weight-entry-date">${date} (W${entry.week})</span><span class="weight-entry-val">${entry.weight} lbs ${trend}</span></div>`;
  }).join('');
}

function renderAll() {
  renderWeekGrid('weekGrid');
  renderWeekGrid('runWeekGrid');
  renderPhaseBanner();
  renderWorkouts();
  renderRunning();
  renderWeightCheck();
}

document.querySelectorAll('.tab').forEach(tab => {
  tab.onclick = () => {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    tab.classList.add('active');
    const target = tab.dataset.tab;
    ['lift','run','macros','strategy'].forEach(t => {
      document.getElementById(t + '-section').classList.toggle('section-hidden', t !== target);
    });
  };
});

// Enter key on weight input
document.getElementById('weightInput').addEventListener('keypress', e => {
  if (e.key === 'Enter') saveWeight();
});

renderAll();
</script>
